# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=your-secret-key-change-in-production
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# LLM (OpenAI-compatible API, e.g. MiMo)
LLM_API_KEY=your-api-key
LLM_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
LLM_MODEL=mimo-v2.5-pro
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# Embedding (BGE Large Zh - local)
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DEVICE=cpu
EMBEDDING_DIM=1024

# Reranker (BGE Reranker - local)
RERANKER_MODEL=BAAI/bge-reranker-large
RERANKER_DEVICE=cpu

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=enterprise_rag

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=1800

# Database (MySQL)
DATABASE_URL=mysql+aiomysql://root:changeme@localhost:3306/enterprise_rag

# Retrieval
RETRIEVAL_TOP_K=10
RERANK_TOP_K=5
CHUNK_SIZE=500
CHUNK_OVERLAP=100
MAX_RETRY_COUNT=2

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# LangSmith (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=enterprise-rag
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
